{
    "name": "therepbot",
    "blocks": {
        "entry": "src/main.tsx",
        "triggers": [
            "onPostSubmit",
            "onCommentSubmit",
            "onCommentUpdate",
            "onAppInstall",
            "onAppUpgrade"
        ]
    },
