{
  "private": true,
  "name": "therepbot",
  "version": "31.2.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && devvit upload",
    "patch": "npm run type-check && devvit publish --public --bump patch",
    "minor": "npm run type-check && devvit publish --public --bump minor",
    "major": "npm run type-check && devvit publish --public --bump major",
    "dev": "devvit playtest therepbot",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "test": "vitest run",
    "type-check": "tsc --build",
    "test:unit": "vitest --run",
    "update": "npx devvit update app"
  },
  "dependencies": {
    "@devvit/cli": "0.13.8",
    "@devvit/protos": "0.13.8",
    "@devvit/public-api": "0.13.8",
    "@devvit/shared-types": "^0.13.8",
    "@devvit/start": "0.13.8",
    "@devvit/web": "0.13.8",
    "@hono/node-server": "^1.19.9",
    "@tailwindcss/vite": "^4.3.3",
    "@types/markdown-escape": "^1.1.3",
    "@types/pako": "^2.0.3",
    "@types/pluralize": "^0.0.33",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.13.0",
    "chalk": "^5.4.1",
    "clsx": "2.1.1",
    "cron-parser": "^5.1.1",
    "date-fns": "^4.1.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-sonarjs": "^3.0.4",
    "hono": "4.11.7",
    "json2md": "^2.0.3",
    "markdown-escape": "^2.0.0",
    "pako": "^2.1.0",
    "pluralize": "^8.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "semver": "^7.8.5",
    "tailwind-merge": "3.4.0"
  },
  "allowScripts": {
    "esbuild@0.25.9": true,
    "esbuild@0.27.4": true,
    "protobufjs@7.5.8": true
  },
  "devDependencies": {
    "@types/json2md": "^1.5.4",
    "@types/semver": "^7.7.1"
  }
}
